# =============================================================================
# AGENTE CONTENIDO Y RRSS - Variables de Entorno
# =============================================================================
# Copia este archivo a .env y completa los valores
# cp .env.example .env
# =============================================================================

# Together AI - Generacion de imagenes gratuita (FLUX.1-schnell)
# Registrate en: https://api.together.xyz/
TOGETHER_AI_API_KEY=your_together_ai_api_key_here

# Pixazo - Generacion de imagenes fallback (Stable Diffusion)
# Registrate en: https://pixazo.com/
PIXAZO_API_KEY=your_pixazo_api_key_here

# Perplexity AI - Investigacion de tendencias (free tier)
# Registrate en: https://www.perplexity.ai/
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Google Drive - Service Account para subida automatica
# Instrucciones: https://console.cloud.google.com/
# 1. Crear proyecto -> Habilitar Google Drive API -> Crear Service Account
# 2. Descargar JSON key -> Guardar en credentials/service_account.json
# 3. Compartir carpeta de Drive con el email del service account
GOOGLE_SERVICE_ACCOUNT_FILE=credentials/service_account.json
GOOGLE_DRIVE_ROOT_FOLDER_ID=your_drive_folder_id_here

# Pipeline Settings
PIPELINE_OUTPUT_DIR=output
PIPELINE_LOG_LEVEL=INFO
PIPELINE_TIMEZONE=America/Mexico_City
