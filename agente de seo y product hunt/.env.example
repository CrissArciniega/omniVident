# MercadoLibre API Credentials
# Obtener en: https://developers.mercadolibre.com.ar/devcenter
ML_CLIENT_ID=your_client_id_here
ML_CLIENT_SECRET=your_client_secret_here
ML_REDIRECT_URI=https://localhost:8080/callback

# Exchange Rate API (opcional, free tier)
# Registrar en: https://www.exchangerate-api.com/
EXCHANGE_RATE_API_KEY=your_api_key_here

# Notion (manejado via MCP, no se necesita token manual)
# NOTION_DATABASE_ID se configura en config/notion_config.json
