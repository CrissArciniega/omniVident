# --- Base de Datos ---
DB_PASSWORD=tu_password_aqui
DB_NAME=omnivident

# --- JWT ---
JWT_SECRET=genera_un_secret_seguro_aqui
JWT_EXPIRES_IN=24h

# --- API Keys ---
OPENAI_API_KEY=tu_openai_key
ANTHROPIC_API_KEY=tu_anthropic_key

